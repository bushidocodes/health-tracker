{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["js/**/*.js", "js/**/*.d.ts"],
  "exclude": ["js/vendor/**/*.js"]
}
